generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ANALYST
}

enum ThreatSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  role          Role           @default(ANALYST)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  datasets      Dataset[]
  notifications Notification[]
  activityLogs  ActivityLog[]
}

model Dataset {
  id          String   @id @default(uuid())
  filename    String
  filePath    String
  rowCount    Int
  status      String   @default("uploaded")
  uploadedBy  User     @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime @default(now())
}

model MLModel {
  id            String       @id @default(uuid())
  name          String
  version       String
  accuracy      Float
  f1Score       Float
  isBestModel   Boolean      @default(false)
  modelPath     String
  trainedAt     DateTime     @default(now())
  predictions   Prediction[]
}

model ThreatLog {
  id             String         @id @default(uuid())
  sourceIp       String?
  attackType     String
  severity       ThreatSeverity @default(MEDIUM)
  confidence     Float
  metadata       Json?          // MySQL 8.0 supports JSON
  recommendation String? @db.Text
  timestamp      DateTime       @default(now())
  predictions    Prediction[]
}

model Prediction {
  id          String    @id @default(uuid())
  threat      ThreatLog @relation(fields: [threatId], references: [id])
  threatId    String
  mlModel     MLModel   @relation(fields: [modelId], references: [id])
  modelId     String
  result      String
  probability Float
  createdAt   DateTime  @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  message   String
  isRead    Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}